# ───────────────────────────────────────────────────────────────────────
# Nexus Suite — environment variables
# Copy this file to `.env` and edit. See docs/SELF_HOSTING.md for full guide.
# ───────────────────────────────────────────────────────────────────────

# Database — Prisma datasource URL.
# Default (SQLite, MVP-friendly): file path on local disk.
DATABASE_URL="file:/home/z/my-project/db/custom.db"

# Production (PostgreSQL) — uncomment and edit:
# DATABASE_URL="postgresql://user:password@localhost:5432/nexus?schema=public"

# ─── Auth (NextAuth.js v4) ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# REQUIRED for any non-local deployment.
NEXTAUTH_SECRET="dev-secret-change-me-in-production"

# Canonical app URL — must match your reverse proxy / domain
NEXTAUTH_URL="http://localhost:3000"

# ─── Optional ──────────────────────────────────────────────────────────
# Disable auto-seed of demo org (set to 'false' in production)
# NEXUS_AUTO_SEED="true"
