// Nexus Suite — Prisma Schema
// Phase 1 MVP: Core + Module 1 (Tasks) + Module 3 (Rooms) + Module 9 (Reporting)
// Phase 2 additions: Module 8 (Leave) + Module 4 (Resource) + Module 2 (KRA) + Module 5 (Budget)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE SYSTEM
// ============================================================

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  plan          String   @default("starter") // starter | growth | business | enterprise
  currency      String   @default("INR")
  timezone      String   @default("Asia/Kolkata")
  onboardingDone Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  departments   Department[]
  modules       OrgModule[]
  projects      Project[]
  rooms         Room[]
  bookings      Booking[]
  notifications Notification[]
  auditLogs     AuditLog[]
  tasks         Task[]
  leaves        Leave[]
  attendance    Attendance[]
  allocations   Allocation[]
  kras          Kra[]
  expenses      Expense[]
  budgets       Budget[]
  holidays      Holiday[]
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String?
  avatarUrl     String?
  role          String   @default("employee") // admin | manager | employee | guest
  designation   String?
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  reportingManagerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignedTasks      Task[]       @relation("TaskAssignee")
  reportedTasks      Task[]       @relation("TaskReporter")
  createdProjects    Project[]
  bookings           Booking[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  leaves             Leave[]
  approvedLeaves     Leave[]      @relation("LeaveApprover")
  attendance         Attendance[]
  allocations        Allocation[]
  kras               Kra[]
  expenses           Expense[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Department? @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  users     User[]
  createdAt DateTime @default(now())
}

// Module registry — which modules are enabled for each org
model OrgModule {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  moduleKey String   // "tasks" | "rooms" | "reporting" | "kra" | "budget" ...
  state     String   @default("disabled") // disabled | trial | active | archived
  enabledAt DateTime?
  trialEndsAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, moduleKey])
}

model Notification {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  category  String   @default("general") // task | booking | system | mention | leave | kra | budget
  severity  String   @default("info")    // info | success | warning | error
  readAt    DateTime?
  link      String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String   // e.g. "task.created"
  entityType String
  entityId  String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())
}

// ============================================================
// MODULE 1: Task & Project Management
// ============================================================

model Project {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String   @default("#64748b")
  status      String   @default("active") // active | on_hold | completed | archived
  startDate   DateTime?
  endDate     DateTime?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  tasks       Task[]
  allocations Allocation[]
  expenses    Expense[]
  budgets     Budget[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("todo") // todo | in_progress | in_review | done | blocked
  priority    String   @default("medium") // low | medium | high | urgent
  type        String   @default("task") // task | bug | feature | epic
  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporterId  String?
  reporter    User?    @relation("TaskReporter", fields: [reporterId], references: [id])
  dueDate     DateTime?
  estimateHours Float?
  spentHours  Float    @default(0)
  tags        String?  // comma-separated
  parentId    String?  // subtask support
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// MODULE 3: Meeting Room & Resource Booking
// ============================================================

model Room {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  location    String?
  capacity    Int      @default(8)
  amenities   String?  // comma-separated: projector, whiteboard, video, ...
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  bookings    Booking[]
}

model Booking {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookedById  String
  bookedBy    User     @relation(fields: [bookedById], references: [id])
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  recurring   String?  // none | daily | weekly | monthly (recurrence rule simple)
  status      String   @default("confirmed") // pending | confirmed | cancelled | completed
  attendees   Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// MODULE 8: Leave & Attendance
// ============================================================

model Holiday {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime
  optional  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([orgId, date])
}

model Leave {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // casual | sick | earned | comp_off | maternity | paternity | unpaid | work_from_home
  startDate    DateTime
  endDate      DateTime
  halfDay      Boolean  @default(false)
  status       String   @default("pending") // pending | approved | rejected | cancelled
  reason       String?
  approverId   String?
  approver     User?    @relation("LeaveApprover", fields: [approverId], references: [id])
  approverNote String?
  appliedAt    DateTime @default(now())
  decidedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Attendance {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime  // the calendar day (midnight UTC)
  checkIn     DateTime?
  checkOut    DateTime?
  workMode    String   @default("office") // office | remote | hybrid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, userId, date])
}

// ============================================================
// MODULE 4: Resource & Capacity Management
// ============================================================

model Allocation {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allocationPct Int      @default(100) // 0-100
  role          String?  // e.g. "Frontend Engineer", "Lead"
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// MODULE 2: KRA / KPA & Performance Management
// ============================================================

model Kra {
  id             String   @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  cycle          String   // e.g. "Q1-2026"
  status         String   @default("draft") // draft | self_review | manager_review | calibration | closed
  weight         Float    @default(25)  // 0-100
  targetRating   Int      @default(3)   // 1-5
  selfRating     Int?
  managerRating  Int?
  selfComment    String?
  managerComment String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================================
// MODULE 5: Budget & Financial Tracking
// ============================================================

model Budget {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  totalAmount Float
  currency    String   @default("INR")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  incurredById String
  incurredBy   User     @relation(fields: [incurredById], references: [id])
  title        String
  amount       Float
  currency     String   @default("INR")
  category     String   @default("other") // software | hardware | travel | meals | contractor | marketing | training | other
  incurredDate DateTime
  vendor       String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
