// Nexus Suite — Prisma Schema
// Phase 1 MVP: Core + Module 1 (Tasks) + Module 3 (Rooms) + Module 9 (Reporting)
// Phase 2 additions: Module 8 (Leave) + Module 4 (Resource) + Module 2 (KRA) + Module 5 (Budget)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE SYSTEM
// ============================================================

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  plan          String   @default("starter") // starter | growth | business | enterprise
  currency      String   @default("INR")
  timezone      String   @default("Asia/Kolkata")
  onboardingDone Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  departments   Department[]
  modules       OrgModule[]
  projects      Project[]
  rooms         Room[]
  bookings      Booking[]
  notifications Notification[]
  auditLogs     AuditLog[]
  tasks         Task[]
  leaves        Leave[]
  attendance    Attendance[]
  allocations   Allocation[]
  kras          Kra[]
  expenses      Expense[]
  budgets       Budget[]
  holidays      Holiday[]
  apiKeys       ApiKey[]
  webhooks      Webhook[]
  documents     Document[]
  risks         Risk[]
  issues        Issue[]
  changeRequests ChangeRequest[]
  policies      Policy[]
  signatures    Signature[]
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String?
  avatarUrl     String?
  role          String   @default("employee") // admin | manager | employee | guest
  designation   String?
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  reportingManagerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignedTasks      Task[]       @relation("TaskAssignee")
  reportedTasks      Task[]       @relation("TaskReporter")
  createdProjects    Project[]
  bookings           Booking[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  leaves             Leave[]
  approvedLeaves     Leave[]      @relation("LeaveApprover")
  attendance         Attendance[]
  allocations        Allocation[]
  kras               Kra[]
  expenses           Expense[]
  // Phase 3 relations
  ownedRisks         Risk[]       @relation("RiskOwner")
  reportedIssues     Issue[]      @relation("IssueReporter")
  assignedIssues     Issue[]      @relation("IssueAssignee")
  requestedChangeRequests ChangeRequest[] @relation("ChangeRequestRequester")
  updatedPolicies    Policy[]     @relation("PolicyUpdatedBy")
}

model Department {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Department? @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  users     User[]
  createdAt DateTime @default(now())
}

// Module registry — which modules are enabled for each org
model OrgModule {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  moduleKey String   // "tasks" | "rooms" | "reporting" | "kra" | "budget" ...
  state     String   @default("disabled") // disabled | trial | active | archived
  enabledAt DateTime?
  trialEndsAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, moduleKey])
}

model Notification {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  category  String   @default("general") // task | booking | system | mention | leave | kra | budget
  severity  String   @default("info")    // info | success | warning | error
  readAt    DateTime?
  link      String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String   // e.g. "task.created"
  entityType String
  entityId  String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())
}

// ============================================================
// MODULE 1: Task & Project Management
// ============================================================

model Project {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String   @default("#64748b")
  status      String   @default("active") // active | on_hold | completed | archived
  startDate   DateTime?
  endDate     DateTime?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  tasks       Task[]
  allocations Allocation[]
  expenses    Expense[]
  budgets     Budget[]
  risks       Risk[]
  issues      Issue[]
  changeRequests ChangeRequest[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("todo") // todo | in_progress | in_review | done | blocked
  priority    String   @default("medium") // low | medium | high | urgent
  type        String   @default("task") // task | bug | feature | epic
  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporterId  String?
  reporter    User?    @relation("TaskReporter", fields: [reporterId], references: [id])
  dueDate     DateTime?
  estimateHours Float?
  spentHours  Float    @default(0)
  tags        String?  // comma-separated
  parentId    String?  // subtask support
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// MODULE 3: Meeting Room & Resource Booking
// ============================================================

model Room {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  location    String?
  capacity    Int      @default(8)
  amenities   String?  // comma-separated: projector, whiteboard, video, ...
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  bookings    Booking[]
}

model Booking {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookedById  String
  bookedBy    User     @relation(fields: [bookedById], references: [id])
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  recurring   String?  // none | daily | weekly | monthly (recurrence rule simple)
  status      String   @default("confirmed") // pending | confirmed | cancelled | completed
  attendees   Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// MODULE 8: Leave & Attendance
// ============================================================

model Holiday {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  date      DateTime
  optional  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([orgId, date])
}

model Leave {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String   // casual | sick | earned | comp_off | maternity | paternity | unpaid | work_from_home
  startDate    DateTime
  endDate      DateTime
  halfDay      Boolean  @default(false)
  status       String   @default("pending") // pending | approved | rejected | cancelled
  reason       String?
  approverId   String?
  approver     User?    @relation("LeaveApprover", fields: [approverId], references: [id])
  approverNote String?
  appliedAt    DateTime @default(now())
  decidedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Attendance {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date        DateTime  // the calendar day (midnight UTC)
  checkIn     DateTime?
  checkOut    DateTime?
  workMode    String   @default("office") // office | remote | hybrid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, userId, date])
}

// ============================================================
// MODULE 4: Resource & Capacity Management
// ============================================================

model Allocation {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  allocationPct Int      @default(100) // 0-100
  role          String?  // e.g. "Frontend Engineer", "Lead"
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// MODULE 2: KRA / KPA & Performance Management
// ============================================================

model Kra {
  id             String   @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  cycle          String   // e.g. "Q1-2026"
  status         String   @default("draft") // draft | self_review | manager_review | calibration | closed
  weight         Float    @default(25)  // 0-100
  targetRating   Int      @default(3)   // 1-5
  selfRating     Int?
  managerRating  Int?
  selfComment    String?
  managerComment String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ============================================================
// MODULE 5: Budget & Financial Tracking
// ============================================================

model Budget {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  totalAmount Float
  currency    String   @default("INR")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Expense {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  incurredById String
  incurredBy   User     @relation(fields: [incurredById], references: [id])
  title        String
  amount       Float
  currency     String   @default("INR")
  // FX: original amount in original currency before conversion to org currency
  originalAmount Float?
  originalCurrency String?
  fxRate       Float?   // rate used to convert to org currency
  category     String   @default("other") // software | hardware | travel | meals | contractor | marketing | training | other
  incurredDate DateTime
  vendor       String?
  vendorGstin  String?  // vendor GSTIN for tax compliance
  notes        String?
  // GST fields (PRD §4 — CGST/SGST/IGST, HSN/SAC)
  hsnSac       String?  // HSN/SAC code
  gstType      String   @default("none") // none | intra (CGST+SGST) | inter (IGST)
  cgstRate     Float    @default(0)      // %
  sgstRate     Float    @default(0)      // %
  igstRate     Float    @default(0)      // %
  cgstAmount   Float    @default(0)
  sgstAmount   Float    @default(0)
  igstAmount   Float    @default(0)
  totalWithTax Float    @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============================================================
// CORE: API Keys (Public API v1 auth — PRD §4.5)
// ============================================================

model ApiKey {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String   // human-readable label
  keyHash     String   @unique // bcrypt hash of the key; the raw key is shown once at creation
  keyPrefix   String   // first 8 chars, shown in lists so users can identify keys
  scopes      String   @default("read") // comma-separated: read | write | webhooks
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdById String?
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// CORE: Webhooks (PRD §4.5 — HMAC-signed event delivery)
// ============================================================

model Webhook {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  url           String
  secret        String   // HMAC signing secret, never exposed after creation
  events        String   @default("*") // comma-separated event filters, or * for all
  active        Boolean  @default(true)
  lastResponseCode Int?
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  failureCount  Int      @default(0)
  deliveries    WebhookDelivery[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  webhookId    String
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event        String
  payload      String   // JSON string
  signature    String
  status       String   @default("pending") // pending | delivered | failed | retrying
  responseCode Int?
  responseBody String?
  attempt      Int      @default(0)
  nextRetryAt  DateTime?
  deliveredAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([webhookId, status])
  @@index([nextRetryAt])
}

// ============================================================
// MODULE 7: Collaboration & Docs (Phase 2 — docs only, chat deferred)
// ============================================================

model Document {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title       String
  slug        String   // url-friendly title
  content     String   @default("") // markdown
  parentId    String?  // for nested pages
  parent      Document? @relation("DocumentTree", fields: [parentId], references: [id])
  children    Document[] @relation("DocumentTree")
  versions    DocumentVersion[]
  createdById String?
  updatedById String?
  version     Int      @default(1)
  isPublic    Boolean  @default(false) // visible to guests/clients
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([orgId, slug])
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version     Int
  content     String
  editedById  String?
  editedAt    DateTime @default(now())
  changeSummary String?

  @@unique([documentId, version])
}

// ============================================================
// MODULE 6: Risk & Issue Management (Phase 3)
// ============================================================

model Risk {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title       String
  description String?
  category    String   @default("operational") // operational | financial | strategic | compliance | technical | external
  likelihood  Int      @default(3) // 1-5
  impact      Int      @default(3) // 1-5
  // severity is computed: likelihood * impact (1-25), but stored for filtering
  severity    Int      @default(9) // stored: likelihood * impact
  status      String   @default("open") // open | mitigating | monitoring | closed | accepted
  ownerId     String?
  owner       User?    @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  mitigation  String?
  dueDate     DateTime?
  identifiedAt DateTime @default(now())
  closedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Issue {
  id             String   @id @default(cuid())
  orgId          String
  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  severity       String   @default("medium") // low | medium | high | critical
  status         String   @default("open") // open | in_progress | resolved | closed
  reporterId     String?
  reporter       User?    @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  assigneeId     String?
  assignee       User?    @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  escalationLevel Int    @default(0) // 0=none, 1=L1, 2=L2, 3=L3
  dueDate        DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ChangeRequest {
  id              String   @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title           String
  description     String?
  type            String   @default("minor") // minor | major | emergency
  status          String   @default("pending") // pending | approved | rejected | implemented
  requestedById   String?
  requestedBy     User?    @relation("ChangeRequestRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  impactAssessment String?
  implementationNotes String?
  dueDate         DateTime?
  decidedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================
// MODULE 10: Governance, Compliance & Audit (Phase 3)
// All features ship free/open-source per PRD v2.1 — not Enterprise-gated.
// ============================================================

model Policy {
  id            String   @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type          String   // retention | ip_allowlist | sso_enforcement | data_residency | password
  name          String
  config        String   // JSON string with policy-specific fields
  active        Boolean  @default(true)
  updatedById   String?
  updatedBy     User?    @relation("PolicyUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([orgId, type])
}

model Signature {
  id           String   @id @default(cuid())
  orgId        String
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  documentType String   // document | kra | expense | change_request
  documentId   String
  signerId     String
  signerEmail  String
  status       String   @default("pending") // pending | signed | declined | expired
  signedAt     DateTime?
  signatureHash String?  // hash of signer + timestamp + document content for tamper-evidence
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
}

