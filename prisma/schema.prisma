// Nexus Suite — Prisma Schema
// Phase 1 MVP: Core + Module 1 (Tasks) + Module 3 (Room Booking) + Module 9 (Reporting)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// CORE SYSTEM
// ============================================================

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  plan          String   @default("starter") // starter | growth | business | enterprise
  currency      String   @default("INR")
  timezone      String   @default("Asia/Kolkata")
  onboardingDone Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  departments   Department[]
  modules       OrgModule[]
  projects      Project[]
  rooms         Room[]
  bookings      Booking[]
  notifications Notification[]
  auditLogs     AuditLog[]
  tasks         Task[]
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String?
  avatarUrl     String?
  role          String   @default("employee") // admin | manager | employee | guest
  designation   String?
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id])
  reportingManagerId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignedTasks      Task[]       @relation("TaskAssignee")
  reportedTasks      Task[]       @relation("TaskReporter")
  createdProjects    Project[]
  bookings           Booking[]
  notifications      Notification[]
  auditLogs          AuditLog[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Department? @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  users     User[]
  createdAt DateTime @default(now())
}

// Module registry — which modules are enabled for each org
model OrgModule {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  moduleKey String   // "tasks" | "rooms" | "reporting" | "kra" | "budget" ...
  state     String   @default("disabled") // disabled | trial | active | archived
  enabledAt DateTime?
  trialEndsAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, moduleKey])
}

model Notification {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  category  String   @default("general") // task | booking | system | mention
  severity  String   @default("info")    // info | success | warning | error
  readAt    DateTime?
  link      String?
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String   // e.g. "task.created"
  entityType String
  entityId  String?
  metadata  String?  // JSON string
  createdAt DateTime @default(now())
}

// ============================================================
// MODULE 1: Task & Project Management
// ============================================================

model Project {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String   @default("#64748b")
  status      String   @default("active") // active | on_hold | completed | archived
  startDate   DateTime?
  endDate     DateTime?
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  tasks       Task[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String   @default("todo") // todo | in_progress | in_review | done | blocked
  priority    String   @default("medium") // low | medium | high | urgent
  type        String   @default("task") // task | bug | feature | epic
  assigneeId  String?
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporterId  String?
  reporter    User?    @relation("TaskReporter", fields: [reporterId], references: [id])
  dueDate     DateTime?
  estimateHours Float?
  spentHours  Float    @default(0)
  tags        String?  // comma-separated
  parentId    String?  // subtask support
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// MODULE 3: Meeting Room & Resource Booking
// ============================================================

model Room {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  location    String?
  capacity    Int      @default(8)
  amenities   String?  // comma-separated: projector, whiteboard, video, ...
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  bookings    Booking[]
}

model Booking {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  roomId      String
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookedById  String
  bookedBy    User     @relation(fields: [bookedById], references: [id])
  title       String
  description String?
  startTime   DateTime
  endTime     DateTime
  recurring   String?  // none | daily | weekly | monthly (recurrence rule simple)
  status      String   @default("confirmed") // pending | confirmed | cancelled | completed
  attendees   Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
